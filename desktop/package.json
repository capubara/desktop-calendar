{
  "name": "fantasia-calendar-desktop",
  "version": "1.0.0",
  "description": "Fantasia Calendar desktop shell",
  "author": "capubara",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "npm run dist:win",
    "dist:win": "set ELECTRON_CACHE=.cache\\electron&& set ELECTRON_BUILDER_CACHE=.cache\\electron-builder&& electron-builder --win nsis",
    "dist:linux": "electron-builder --linux AppImage deb",
    "dist:mac": "electron-builder --mac dmg zip"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "local.fantasia.calendar",
    "productName": "Fantasia Calendar",
    "files": [
      "main.js"
    ],
    "extraResources": [
      {
        "from": "../app",
        "to": "server/app"
      },
      {
        "from": "../public",
        "to": "server/public"
      },
      {
        "from": "../storage",
        "to": "server/storage"
      },
      {
        "from": "vendor/php",
        "to": "php",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "artifactName": "Fantasia-Calendar-Setup-${version}.${ext}"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns",
      "artifactName": "Fantasia-Calendar-${version}-mac.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png",
      "category": "Utility",
      "artifactName": "Fantasia-Calendar-${version}-linux.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
